# Optional overrides — copy to .env and uncomment to customize.
# Paths are relative to the repo root (plant-tracking/).
#
# Local development defaults:
# DATABASE_URL=sqlite:///./data/plant_tracking.db
# UPLOAD_DIR=./data/uploads
# DATA_DIR=./data
#
# Docker Compose sets these in docker-compose.yml instead:
# DATABASE_URL=sqlite:////data/plant_tracking.db
# UPLOAD_DIR=/data/uploads
# DATA_DIR=/data
# STATIC_DIR=/app/static
